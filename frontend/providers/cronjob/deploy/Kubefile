FROM scratch

USER 65532:65532

COPY registry registry
COPY charts charts
COPY cronjob-frontend-entrypoint.sh cronjob-frontend-entrypoint.sh

ENV cloudDomain="127.0.0.1.nip.io"
ENV cloudPort=""
ENV httpPort=""
ENV disableHttps="false"
ENV certSecretName="wildcard-cert"

ENV SUCCESSFUL_JOBS_HISTORY_LIMIT=""
ENV FAILED_JOBS_HISTORY_LIMIT=""

CMD ["bash cronjob-frontend-entrypoint.sh"]
