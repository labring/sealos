{
  "extends": "../../tsconfig.web.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "target": "ES2020",
    "forceConsistentCasingInFileNames": false,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"],
      "@/config": ["./src/config.ts"],
      "prisma/*": ["prisma/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.d.ts", ".next/types/**/*.ts"]
}
