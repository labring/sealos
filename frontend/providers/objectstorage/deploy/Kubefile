FROM scratch

USER 65532:65532

COPY registry registry
COPY charts charts
COPY objectstorage-frontend-entrypoint.sh objectstorage-frontend-entrypoint.sh

ENV cloudDomain="127.0.0.1.nip.io"
ENV cloudPort=""
ENV certSecretName="wildcard-cert"
ENV monitorUrl="http://object-storage-monitor.objectstorage-system.svc.cluster.local:9090/q"
ENV appLaunchpadUrl="http://applaunchpad-frontend.applaunchpad-frontend.svc.cluster.local:3000/api/v1alpha"
ENV accountServer="http://account-service.account-system.svc:2333"

CMD ["bash objectstorage-frontend-entrypoint.sh"]
