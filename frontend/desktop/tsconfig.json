{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "prisma/*": ["prisma/*"]
    },
    "isolatedModules": true,
    "types": ["node", "vitest/globals"],
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "./scripts/**/*.ts",
    "./prisma/**/*.ts",
    "src/types/i18next.d.ts"
  ],
  "extends": "../tsconfig.web.json"
}
